FROM node:22

WORKDIR /app

COPY . .

# Enable Corepack and set pnpm to version 8.15.0 (matches your lockfile)
RUN corepack enable && corepack prepare pnpm@8.15.0 --activate

# Install dependencies using your existing lockfile
RUN pnpm install --frozen-lockfile

# Build app
RUN pnpm run build

EXPOSE 3000

CMD ["pnpm", "run", "start"]