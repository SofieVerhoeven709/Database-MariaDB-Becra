model FollowUpTarget {
  id         String   @id @db.Char(36)
  followUpId String   @db.Char(36)
  targetId   String   @db.Char(36)
  FollowUp   FollowUp @relation(fields: [followUpId], references: [id], onUpdate: Restrict, map: "FollowUpTarget_ibfk_1")
  Target     Target   @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "FollowUpTarget_ibfk_2")

  @@index([followUpId], map: "followUpId")
  @@index([targetId], map: "targetId")
