model FollowUp {
  id                                     String              @id @db.Char(36)
  activityDescription                    String?             @db.Text
  aditionalInfo                          String?             @db.Text
  actionAgenda                           DateTime?           @db.DateTime(0)
  closedAgenda                           DateTime?           @db.DateTime(0)
  recurringCallDays                      Int?
  createdAt                              DateTime            @db.DateTime(0)
  itemClosed                             Boolean             @default(false)
  salesFollowUp                          Boolean             @default(false)
  nonConform                             Boolean             @default(false)
  periodicControl                        Boolean             @default(false)
  recurringActive                        Boolean             @default(false)
  review                                 Boolean             @default(false)
  createdBy                              String              @db.Char(36)
  ownedBy                                String              @db.Char(36)
  statusId                               String              @db.Char(36)
  executedBy                             String              @db.Char(36)
  urgencyTypeId                          String              @db.Char(36)
  documentId                             String              @db.Char(36)
  targetId                               String              @db.Char(36)
  followUpTypeId                         String              @db.Char(36)
  UrgencyType                            UrgencyType         @relation(fields: [urgencyTypeId], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_1")
  Employee_FollowUp_ownedByToEmployee    Employee            @relation("FollowUp_ownedByToEmployee", fields: [ownedBy], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_2")
  Status                                 Status              @relation(fields: [statusId], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_3")
  Employee_FollowUp_executedByToEmployee Employee            @relation("FollowUp_executedByToEmployee", fields: [executedBy], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_4")
  DocumentStructure                      DocumentStructure   @relation(fields: [documentId], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_5")
  Employee_FollowUp_createdByToEmployee  Employee            @relation("FollowUp_createdByToEmployee", fields: [createdBy], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_6")
  FollowUpType                           FollowUpType        @relation(fields: [followUpTypeId], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_7")
  Target                                 Target              @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "FollowUp_ibfk_8")
  FollowUpStructure                      FollowUpStructure[]
  FollowUpTarget                         FollowUpTarget[]

  @@index([createdBy], map: "createdBy")
  @@index([documentId], map: "documentId")
  @@index([executedBy], map: "executedBy")
  @@index([followUpTypeId], map: "followUpTypeId")
  @@index([ownedBy], map: "ownedBy")
  @@index([statusId], map: "statusId")
  @@index([targetId], map: "targetId")
  @@index([urgencyTypeId], map: "urgencyTypeId")
}

