generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Certificate {
  id                String             @id @db.Char(36)
  description       String?            @db.Text
  descriptionShort  String?            @db.Text
  createdAt         DateTime           @db.DateTime(0)
  createdBy         String             @db.Char(36)
  certificateTypeId String             @db.Char(36)
  targetId          String             @db.Char(36)
  Employee          Employee           @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "Certificate_ibfk_1")
  CertificateType   CertificateType    @relation(fields: [certificateTypeId], references: [id], onUpdate: Restrict, map: "Certificate_ibfk_2")
  Target            Target             @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "Certificate_ibfk_3")
  TrainingStandard  TrainingStandard[]

  @@index([certificateTypeId], map: "certificateTypeId")
  @@index([createdBy], map: "createdBy")
  @@index([targetId], map: "targetId")
}

model CertificateType {
  id          String        @id @db.Char(36)
  name        String        @db.VarChar(100)
  createdAt   DateTime      @db.DateTime(0)
  createdBy   String        @db.Char(36)
  Certificate Certificate[]
  Employee    Employee      @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "CertificateType_ibfk_1")

  @@index([createdBy], map: "createdBy")
}

model Company {
  id                     String                  @id @db.Char(36)
  name                   String                  @db.VarChar(100)
  number                 String                  @db.VarChar(100)
  mail                   String?                 @db.VarChar(100)
  businessPhone          String?                 @db.VarChar(100)
  website                String?                 @db.VarChar(100)
  vatNumber              String?                 @db.VarChar(100)
  bankNumber             String?                 @db.VarChar(100)
  iban                   String?                 @db.VarChar(100)
  bic                    String?                 @db.VarChar(100)
  becraCustomerNumber    String?                 @db.VarChar(100)
  becraWebsiteLogin      String?                 @db.VarChar(100)
  supplier               Boolean                 @default(false)
  prefferedSupplier      Boolean                 @default(false)
  companyActive          Boolean                 @default(true)
  newsLetter             Boolean                 @default(false)
  customer               Boolean                 @default(false)
  potentialCustomer      Boolean                 @default(false)
  headQuarters           Boolean                 @default(false)
  potentialSubContractor Boolean                 @default(false)
  subContractor          Boolean                 @default(false)
  notes                  String?                 @db.Text
  createdAt              DateTime                @db.DateTime(0)
  createdBy              String                  @db.Char(36)
  companyId              String?                 @db.Char(36)
  targetId               String                  @db.Char(36)
  Employee               Employee                @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "Company_ibfk_1")
  Company                Company?                @relation("CompanyToCompany", fields: [companyId], references: [id], onUpdate: Restrict, map: "Company_ibfk_2")
  other_Company          Company[]               @relation("CompanyToCompany")
  Target                 Target                  @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "Company_ibfk_3")
  CompanyAdress          CompanyAdress[]
  CompanyContact         CompanyContact[]
  DeliveryNote           DeliveryNote[]
  InventoryOrder         InventoryOrder[]
  MaterialSerialTracked  MaterialSerialTracked[]
  Project                Project[]

  @@index([companyId], map: "companyId")
  @@index([createdBy], map: "createdBy")
  @@index([targetId], map: "targetId")
}

model CompanyAdress {
  id          String   @id @db.Char(36)
  street      String?  @db.VarChar(100)
  houseNumber String?  @db.VarChar(100)
  busNumber   String?  @db.VarChar(100)
  zipCode     String?  @db.VarChar(100)
  place       String?  @db.VarChar(100)
  createdAt   DateTime @db.DateTime(0)
  typeAdress  String?  @db.VarChar(100)
  createdBy   String   @db.Char(36)
  companyId   String   @db.Char(36)
  Employee    Employee @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "CompanyAdress_ibfk_1")
  Company     Company  @relation(fields: [companyId], references: [id], onUpdate: Restrict, map: "CompanyAdress_ibfk_2")

  @@index([companyId], map: "companyId")
  @@index([createdBy], map: "createdBy")
}

model CompanyContact {
  id              String    @id @db.Char(36)
  startedDate     DateTime  @db.DateTime(0)
  endDate         DateTime? @db.DateTime(0)
  roleWithCompany String?   @db.VarChar(100)
  createdAt       DateTime  @db.DateTime(0)
  contactId       String    @db.Char(36)
  companyId       String    @db.Char(36)
  createdBy       String    @db.Char(36)
  Employee        Employee  @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "CompanyContact_ibfk_1")
  Contact         Contact   @relation(fields: [contactId], references: [id], onUpdate: Restrict, map: "CompanyContact_ibfk_2")
  Company         Company   @relation(fields: [companyId], references: [id], onUpdate: Restrict, map: "CompanyContact_ibfk_3")

  @@index([companyId], map: "companyId")
  @@index([contactId], map: "contactId")
  @@index([createdBy], map: "createdBy")
}

model Contact {
  id                                 String              @id @db.Char(36)
  firstName                          String              @db.VarChar(100)
  lastName                           String              @db.VarChar(100)
  mail1                              String?             @db.VarChar(100)
  mail2                              String?             @db.VarChar(100)
  mail3                              String?             @db.VarChar(100)
  generalPhone                       String?             @db.VarChar(100)
  homePhone                          String?             @db.VarChar(100)
  mobilePhone                        String?             @db.VarChar(100)
  info                               String?             @db.Text
  birthDate                          DateTime?           @db.DateTime(0)
  trough                             String?             @db.VarChar(100)
  description                        String?             @db.Text
  createdAt                          DateTime            @db.DateTime(0)
  infoCorrect                        Boolean             @default(false)
  checkInfo                          Boolean             @default(false)
  newYearCard                        Boolean             @default(false)
  active                             Boolean             @default(true)
  newsLetter                         Boolean             @default(false)
  mailing                            Boolean             @default(false)
  trainingAdvice                     Boolean             @default(false)
  contactForTrainingAndAdvice        Boolean             @default(false)
  customerTrainingAndAdvice          Boolean             @default(false)
  potentialCustomerTrainingAndAdvice Boolean             @default(false)
  potentialTeacherTrainingAndAdvice  Boolean             @default(false)
  teacherTrainingAndAdvice           Boolean             @default(false)
  participantTrainingAndAdvice       Boolean             @default(false)
  createdBy                          String              @db.Char(36)
  functionId                         String?             @db.Char(36)
  departmentId                       String?             @db.Char(36)
  titleId                            String?             @db.Char(36)
  businessCardId                     String?             @db.Char(36)
  targetId                           String              @db.Char(36)
  CompanyContact                     CompanyContact[]
  Employee                           Employee            @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "Contact_ibfk_1")
  Function                           Function?           @relation(fields: [functionId], references: [id], onUpdate: Restrict, map: "Contact_ibfk_2")
  Department                         Department?         @relation(fields: [departmentId], references: [id], onUpdate: Restrict, map: "Contact_ibfk_3")
  Title                              Title?              @relation(fields: [titleId], references: [id], onUpdate: Restrict, map: "Contact_ibfk_4")
  DocumentStructure                  DocumentStructure?  @relation(fields: [businessCardId], references: [id], onUpdate: Restrict, map: "Contact_ibfk_5")
  Target                             Target              @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "Contact_ibfk_6")
  FollowUpStructure                  FollowUpStructure[]
  ProjectContact                     ProjectContact[]
  TrainingContact                    TrainingContact[]

  @@index([businessCardId], map: "businessCardId")
  @@index([createdBy], map: "createdBy")
  @@index([departmentId], map: "departmentId")
  @@index([functionId], map: "functionId")
  @@index([targetId], map: "targetId")
  @@index([titleId], map: "titleId")
}

model Department {
  id                                         String     @id @db.Char(36)
  name                                       String     @db.VarChar(100)
  color                                      String?    @db.VarChar(10)
  icon                                       String?    @db.VarChar(255)
  description                                String?    @db.VarChar(255)
  createdAt                                  DateTime   @db.DateTime(0)
  createdBy                                  String     @db.Char(36)
  Contact                                    Contact[]
  Employee_Department_createdByToEmployee    Employee   @relation("Department_createdByToEmployee", fields: [createdBy], references: [id], onUpdate: Restrict, map: "fk_department_createdBy")
  Employee_Employee_departmentIdToDepartment Employee[] @relation("Employee_departmentIdToDepartment")

  @@index([createdBy], map: "fk_department_createdBy")
}

model DocumentStructure {
  id                                               String                           @id @db.Char(36)
  documentNumber                                   String                           @db.VarChar(100)
  description                                      String?                          @db.Text
  descriptionShort                                 String                           @db.VarChar(100)
  createdAt                                        DateTime                         @db.DateTime(0)
  expiryDate                                       DateTime?                        @db.DateTime(0)
  revisionNumber                                   Int?
  revisionDetail                                   String?                          @db.Text
  valid                                            Boolean                          @default(true)
  process                                          Boolean                          @default(false)
  aditionalInfo                                    String?                          @db.Text
  referenceDocId                                   String?                          @db.Char(36)
  roleId                                           String?                          @db.Char(36)
  createdBy                                        String                           @db.Char(36)
  revisedById                                      String                           @db.Char(36)
  managedById                                      String                           @db.Char(36)
  targetId                                         String                           @db.Char(36)
  Contact                                          Contact[]
  DeliveryNote                                     DeliveryNote[]
  DocumentStructure                                DocumentStructure?               @relation("DocumentStructureToDocumentStructure", fields: [referenceDocId], references: [id], onUpdate: Restrict, map: "DocumentStructure_ibfk_1")
  other_DocumentStructure                          DocumentStructure[]              @relation("DocumentStructureToDocumentStructure")
  Role                                             Role?                            @relation(fields: [roleId], references: [id], onUpdate: Restrict, map: "DocumentStructure_ibfk_2")
  Employee_DocumentStructure_createdByToEmployee   Employee                         @relation("DocumentStructure_createdByToEmployee", fields: [createdBy], references: [id], onUpdate: Restrict, map: "fk_documentStructure_createdBy")
  Employee_DocumentStructure_managedByIdToEmployee Employee                         @relation("DocumentStructure_managedByIdToEmployee", fields: [managedById], references: [id], onUpdate: Restrict, map: "fk_documentStructure_managedBy")
  Employee_DocumentStructure_revisedByIdToEmployee Employee                         @relation("DocumentStructure_revisedByIdToEmployee", fields: [revisedById], references: [id], onUpdate: Restrict, map: "fk_documentStructure_revisedBy")
  Target                                           Target                           @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "fk_documentStructure_target")
  Employee_Employee_pictureIdToDocumentStructure   Employee[]                       @relation("Employee_pictureIdToDocumentStructure")
  FollowUp                                         FollowUp[]
  FollowUpStructure                                FollowUpStructure[]
  InventoryOrderStructure                          InventoryOrderStructure[]
  MaterialSerialTrackedStructure                   MaterialSerialTrackedStructure[]
  MaterialStructure                                MaterialStructure[]
  TrainingDocument                                 TrainingDocument[]

  @@index([createdBy], map: "fk_documentStructure_createdBy")
  @@index([managedById], map: "fk_documentStructure_managedBy")
  @@index([revisedById], map: "fk_documentStructure_revisedBy")
  @@index([targetId], map: "fk_documentStructure_target")
  @@index([referenceDocId], map: "referenceDocId")
  @@index([roleId], map: "roleId")
}

model EmergencyContact {
  id           String   @id @db.Char(36)
