  Function                             Function?           @relation(fields: [functionId], references: [id], onUpdate: Restrict, map: "Contact_ibfk_2")
  DepartmentExtern                     DepartmentExtern?   @relation(fields: [departmentExternId], references: [id], onUpdate: Restrict, map: "Contact_ibfk_3")
