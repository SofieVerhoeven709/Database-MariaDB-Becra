generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Certificate {
  id                                       String                           @id @db.Char(36)
  description                              String?                          @db.Text
  descriptionShort                         String?                          @db.Text
  createdAt                                DateTime                         @db.DateTime(0)
  createdBy                                String                           @db.Char(36)
  certificateTypeId                        String                           @db.Char(36)
  targetId                                 String                           @db.Char(36)
  deleted                                  Boolean                          @default(false)
  deletedAt                                DateTime?                        @db.DateTime(0)
  deletedBy                                String?                          @db.Char(36)
  Employee                                 Employee                         @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "Certificate_ibfk_1")
  CertificateType                          CertificateType                  @relation(fields: [certificateTypeId], references: [id], onUpdate: Restrict, map: "Certificate_ibfk_2")
  Target                                   Target                           @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "Certificate_ibfk_3")
  Employee_Certificate_deletedByToEmployee Employee?                        @relation("Certificate_deletedByToEmployee", fields: [deletedBy], references: [id], onUpdate: Restrict, map: "Certificate_ibfk_4")
  MaterialSerialTrackedStructure           MaterialSerialTrackedStructure[]
  TrainingStandard                         TrainingStandard[]

  @@index([certificateTypeId], map: "certificateTypeId")
  @@index([createdBy], map: "createdBy")
  @@index([targetId], map: "targetId")
  @@index([deletedBy], map: "deletedBy")
}

model CertificateType {
  id                                           String        @id @db.Char(36)
  name                                         String        @db.VarChar(100)
  createdAt                                    DateTime      @db.DateTime(0)
  createdBy                                    String        @db.Char(36)
  deleted                                      Boolean       @default(false)
  deletedAt                                    DateTime?     @db.DateTime(0)
  deletedBy                                    String?       @db.Char(36)
  Certificate                                  Certificate[]
  Employee                                     Employee      @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "CertificateType_ibfk_1")
  Employee_CertificateType_deletedByToEmployee Employee?     @relation("CertificateType_deletedByToEmployee", fields: [deletedBy], references: [id], onUpdate: Restrict, map: "CertificateType_ibfk_2")

  @@index([createdBy], map: "createdBy")
  @@index([deletedBy], map: "deletedBy")
}

model Company {
  id                                   String                 @id @db.Char(36)
  name                                 String                 @db.VarChar(100)
  number                               String                 @db.VarChar(100)
  mail                                 String?                @db.VarChar(100)
  businessPhone                        String?                @db.VarChar(100)
  website                              String?                @db.VarChar(100)
  vatNumber                            String?                @db.VarChar(100)
  bankNumber                           String?                @db.VarChar(100)
  iban                                 String?                @db.VarChar(100)
  bic                                  String?                @db.VarChar(100)
  becraCustomerNumber                  String?                @db.VarChar(100)
  becraWebsiteLogin                    String?                @db.VarChar(100)
  supplier                             Boolean                @default(false)
  prefferedSupplier                    Boolean                @default(false)
  companyActive                        Boolean                @default(true)
  newsLetter                           Boolean                @default(false)
  customer                             Boolean                @default(false)
  potentialCustomer                    Boolean                @default(false)
  headQuarters                         Boolean                @default(false)
  potentialSubContractor               Boolean                @default(false)
  subContractor                        Boolean                @default(false)
  notes                                String?                @db.Text
  createdAt                            DateTime               @db.DateTime(0)
  createdBy                            String                 @db.Char(36)
  companyId                            String?                @db.Char(36)
  targetId                             String                 @db.Char(36)
  deleted                              Boolean                @default(false)
  deletedAt                            DateTime?              @db.DateTime(0)
  deletedBy                            String?                @db.Char(36)
  Employee                             Employee               @relation(fields: [createdBy], references: [id], onUpdate: Restrict, map: "Company_ibfk_1")
  Company                              Company?               @relation("CompanyToCompany", fields: [companyId], references: [id], onUpdate: Restrict, map: "Company_ibfk_2")
  other_Company                        Company[]              @relation("CompanyToCompany")
  Target                               Target                 @relation(fields: [targetId], references: [id], onUpdate: Restrict, map: "Company_ibfk_3")
  Employee_Company_deletedByToEmployee Employee?              @relation("Company_deletedByToEmployee", fields: [deletedBy], references: [id], onUpdate: Restrict, map: "Company_ibfk_4")
  CompanyAdress                        CompanyAdress[]
  CompanyContact                       CompanyContact[]
  DeliveryNoteSupplier                 DeliveryNoteSupplier[]
  MaterialSerialTrack                  MaterialSerialTrack[]
  Project                              Project[]
  Purchase                             Purchase[]

  @@index([companyId], map: "companyId")
  @@index([createdBy], map: "createdBy")
  @@index([targetId], map: "targetId")
  @@index([deletedBy], map: "deletedBy")
}

model CompanyAdress {
  id                                         String    @id @db.Char(36)
