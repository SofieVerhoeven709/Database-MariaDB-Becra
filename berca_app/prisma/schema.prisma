  endDate                                                   DateTime?              @db.DateTime(0)
  info                                                      String?                @db.Text
  birthDate                                                 DateTime?              @db.DateTime(0)
  street                                                    String?                @db.VarChar(100)
  houseNumber                                               String?                @db.VarChar(100)
  busNumber                                                 String?                @db.VarChar(100)
  zipCode                                                   String?                @db.VarChar(100)
  place                                                     String?                @db.VarChar(100)
  username                                                  String                 @db.VarChar(100)
  createdAt                                                 DateTime               @db.DateTime(0)
  permanentEmployee                                         Boolean                @default(false)
  checkInfo                                                 Boolean                @default(false)
  newYearCard                                               Boolean                @default(false)
  active                                                    Boolean                @default(true)
  passwordCreatedAt                                         DateTime               @db.DateTime(0)
  createdBy                                                 String?                @db.Char(36)
  roleId                                                    String?                @db.Char(36)
  functionId                                                String?                @db.Char(36)
  departmentId                                              String?                @db.Char(36)
  titleId                                                   String?                @db.Char(36)
  pictureId                                                 String?                @db.Char(36)
  Certificate                                               Certificate[]
  CertificateType                                           CertificateType[]
  Company                                                   Company[]
  CompanyAdress                                             CompanyAdress[]
  CompanyContact                                            CompanyContact[]
  Contact                                                   Contact[]
  Department_Department_createdByToEmployee                 Department[]           @relation("Department_createdByToEmployee")
  DocumentStructure_DocumentStructure_createdByToEmployee   DocumentStructure[]    @relation("DocumentStructure_createdByToEmployee")
  DocumentStructure_DocumentStructure_managedByIdToEmployee DocumentStructure[]    @relation("DocumentStructure_managedByIdToEmployee")
  DocumentStructure_DocumentStructure_revisedByIdToEmployee DocumentStructure[]    @relation("DocumentStructure_revisedByIdToEmployee")
  EmergencyContact                                          EmergencyContact[]
  Employee                                                  Employee?              @relation("EmployeeToEmployee", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "Employee_ibfk_1")
  other_Employee                                            Employee[]             @relation("EmployeeToEmployee")
  Role_Employee_roleIdToRole                                Role?                  @relation("Employee_roleIdToRole", fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "Employee_ibfk_2")
  Function_Employee_functionIdToFunction                    Function?              @relation("Employee_functionIdToFunction", fields: [functionId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "Employee_ibfk_3")
  Department_Employee_departmentIdToDepartment              Department?            @relation("Employee_departmentIdToDepartment", fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "Employee_ibfk_4")
  Title_Employee_titleIdToTitle                             Title?                 @relation("Employee_titleIdToTitle", fields: [titleId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "Employee_ibfk_5")
  DocumentStructure_Employee_pictureIdToDocumentStructure   DocumentStructure?     @relation("Employee_pictureIdToDocumentStructure", fields: [pictureId], references: [id], onUpdate: Restrict, map: "Employee_ibfk_6")
  FollowUp_FollowUp_ownedByToEmployee                       FollowUp[]             @relation("FollowUp_ownedByToEmployee")
  FollowUp_FollowUp_executedByToEmployee                    FollowUp[]             @relation("FollowUp_executedByToEmployee")
  FollowUp_FollowUp_createdByToEmployee                     FollowUp[]             @relation("FollowUp_createdByToEmployee")
  FollowUpStructure_FollowUpStructure_ownedByToEmployee     FollowUpStructure[]    @relation("FollowUpStructure_ownedByToEmployee")
  FollowUpStructure_FollowUpStructure_executedByToEmployee  FollowUpStructure[]    @relation("FollowUpStructure_executedByToEmployee")
  FollowUpStructure_FollowUpStructure_taskForToEmployee     FollowUpStructure[]    @relation("FollowUpStructure_taskForToEmployee")
  FollowUpStructure_FollowUpStructure_createdByToEmployee   FollowUpStructure[]    @relation("FollowUpStructure_createdByToEmployee")
  FollowUpType                                              FollowUpType[]
  Function_Function_createdByToEmployee                     Function[]             @relation("Function_createdByToEmployee")
  HourType                                                  HourType[]
  InvoiceIn                                                 InvoiceIn[]
