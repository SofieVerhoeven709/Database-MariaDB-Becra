  invoiceDate           DateTime          @db.DateTime(0)
  expireDate            DateTime          @db.DateTime(0)
  payDate               DateTime?         @db.DateTime(0)
  invoiceReference      String?           @db.VarChar(100)
  invoiceOutAttachement String?           @db.VarChar(100)
  deliveryNote          String?           @db.Text
  purchaseOrder         String?           @db.Text
  transactionNumber     String?           @db.VarChar(100)
  info                  String?           @db.Text
  deliveryInvoiceCode   String?           @db.VarChar(100)
  vatMargin             Float             @db.Float
