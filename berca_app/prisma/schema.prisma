  Employee_CompanyAdress_deletedByToEmployee Employee? @relation("CompanyAdress_deletedByToEmployee", fields: [deletedBy], references: [id], onUpdate: Restrict, map: "CompanyAdress_ibfk_3")

  @@index([companyId], map: "companyId")
  @@index([createdBy], map: "createdBy")
  @@index([deletedBy], map: "deletedBy")
}

model CompanyContact {
  id                                          String    @id @db.Char(36)
  startedDate                                 DateTime  @db.DateTime(0)
