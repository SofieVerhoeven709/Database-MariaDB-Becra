  @@index([createdBy], map: "createdBy")
  @@index([departmentId], map: "departmentId")
  @@index([functionId], map: "functionId")
  @@index([pictureId], map: "pictureId")
  @@index([roleId], map: "roleId")
  @@index([titleId], map: "titleId")
